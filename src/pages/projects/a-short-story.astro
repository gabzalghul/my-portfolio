---
import Layout from "../../layouts/Layout.astro";
import ProjectSlider from "../../components/ProjectSlider.astro";

const imageModules = import.meta.glob(
  "../../images/a-short-story/*.{jpg,jpeg,JPG,JPEG,png,PNG}",
  { eager: true, import: "default" }
);

const images = Object.entries(imageModules)
  .sort(([a], [b]) => {
    const getNumber = (path) => {
      const match = path.match(/-(\d+)\.(jpg|jpeg|png)$/i);
      return match ? Number(match[1]) : 0;
    };
    return getNumber(a) - getNumber(b);
  })
  .map(([, mod]) => mod);
---

<Layout title="A Short Story — Gabriel">
  <section class="hero">
    <h1>A Short Story</h1>
    <p class="project-meta">Narrative Photography / 2025</p>
    <p>
      A staged sequence following a fictional character through a sudden and
      ambiguous event.
    </p>
  </section>

  <ProjectSlider images={images} altPrefix="A Short Story image" />

  <section class="project-description">
    <p>
      A constructed visual narrative exploring tension, ambiguity, and cinematic
      pacing through a limited sequence of images.
    </p>
  </section>
</Layout>
