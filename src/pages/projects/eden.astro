---
import Layout from "../../layouts/Layout.astro";
import ProjectSlider from "../../components/ProjectSlider.astro";

const imageModules = import.meta.glob(
  "../../images/eden/*.{jpg,jpeg,JPG,JPEG,png,PNG}",
  { eager: true, import: "default" }
);

const images = Object.entries(imageModules)
  .sort(([a], [b]) => {
    const getNumber = (path) => {
      const match = path.match(/-(\d+)\.(jpg|jpeg|png)$/i);
      return match ? Number(match[1]) : 0;
    };
    return getNumber(a) - getNumber(b);
  })
  .map(([, mod]) => mod);
---

<Layout title="Eden — Gabriel">
  <section class="hero">
    <h1>Eden</h1>
    <p class="project-meta">Photography / 2026</p>
    <p>A walk through the fog.</p>
  </section>

  <ProjectSlider images={images} altPrefix="Eden image" />

  <section class="project-description">
    <p>
      An ongoing photographic project focused on vegetation, atmosphere, and the
      shifting presence of landscape.
    </p>
  </section>
</Layout>