---
import Layout from "../../layouts/Layout.astro";
import ProjectSlider from "../../components/ProjectSlider.astro";

const imageModules = import.meta.glob(
  "../../images/seethelines/*.{jpg,jpeg,JPG,JPEG,png,PNG}",
  { eager: true, import: "default" }
);

const images = Object.entries(imageModules)
  .sort(([a], [b]) => {
    const getNumber = (path) => {
      const match = path.match(/-(\d+)\.(jpg|jpeg|png)$/i);
      return match ? Number(match[1]) : 0;
    };
    return getNumber(a) - getNumber(b);
  })
  .map(([, mod]) => mod);
---

<Layout title="Seethelines — Gabriel">
  <section class="hero">
    <h1>Seethelines</h1>
    <p class="project-meta">Architecture Photography / 2025–2026</p>
    <p>When the invisible meets the visible.</p>
  </section>

  <ProjectSlider images={images} altPrefix="Seethelines image" />

  <section class="project-description">
    <p>
      A documentary photography project focused on remarkable works of
      architecture across Japan.
    </p>
  </section>
</Layout>
