---
import Layout from "../layouts/Layout.astro";
import portrait from "../images/portrait.jpg";
---

<Layout title="About — Gabriel">
  <section class="about-wrap">
    <img class="about-portrait" src={portrait.src} alt="Portrait of Gabriel" />

    <p class="section-title">About</p>
    <h1>Gabriel</h1>

    <p>
      Architecture student working across photography, space, and visual
      observation.
    </p>

    <p style="margin-top: 16px;">
      This website brings together selected projects developed through study,
      travel, and ongoing personal work.
    </p>

    <div class="about-buttons">
      <a class="about-button" href="mailto:gabriel@gabrielbest.com">
        Contact
      </a>

      <a
        class="about-button"
        href="https://instagram.com/gabzalghul"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg viewBox="0 0 24 24" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8">
          <rect x="3" y="3" width="18" height="18" rx="5"></rect>
          <circle cx="12" cy="12" r="4"></circle>
          <circle cx="17.5" cy="6.5" r="1"></circle>
        </svg>
        Instagram
      </a>
    </div>
  </section>
</Layout>